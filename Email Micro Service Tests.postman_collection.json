  "item": [
    {
      "name": "Welcome Message",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 202 Accepted\", function () {\r",
              "    pm.response.to.have.status(202);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains Welcome message\", function () {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response).to.have.property(\"status\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"to\": \"user@example.com\",\r\n    \"subject\": \"Welcome!\",\r\n    \"body\": \"Thanks for signing up.\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://api.example.com/send-email",
          "protocol": "https",
          "host": [
            "api",
            "example",
